// BetEdge AI — Prisma schema (Neon PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  BASIC
  PRO
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum Sport {
  NFL
  NBA
  MLB
  NHL
  UFC
  SOCCER
}

enum PickResult {
  PENDING
  WIN
  LOSS
  PUSH
  VOID
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  plan          Plan      @default(FREE)
  bankrollCents Int       @default(100000)
  unitSizeCents Int       @default(1000)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
  pickViews    PickView[]
  apiKeys      ApiKey[]
  promoRedeems PromoRedemption[]

  @@index([email])
  @@index([plan])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([status])
}

model Pick {
  id             String     @id @default(cuid())
  date           DateTime   @db.Date
  sport          Sport
  league         String?
  eventName      String
  eventStartsAt  DateTime?
  market         String
  pickSide       String
  oddsAmerican   Int
  bookmaker      String?
  confidence     Float
  edgePercent    Float
  unitsSuggested Float      @default(1)
  reasoning      String     @db.Text
  keyFactors     String[]
  result         PickResult @default(PENDING)
  profitUnits    Float?
  isPremium      Boolean    @default(false)
  modelVersion   String?
  rawPayload     Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  views PickView[]

  @@index([date, sport])
  @@index([date, isPremium])
  @@index([result])
  @@index([createdAt])
}

model PickView {
  id       String   @id @default(cuid())
  userId   String
  pickId   String
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick Pick @relation(fields: [pickId], references: [id], onDelete: Cascade)

  @@unique([userId, pickId])
  @@index([userId, viewedAt])
}

model PerformanceSnapshot {
  id          String   @id @default(cuid())
  period      String
  /// "ALL" or a Sport enum value as string
  sportKey    String   @default("ALL")
  totalPicks  Int      @default(0)
  wins        Int      @default(0)
  losses      Int      @default(0)
  pushes      Int      @default(0)
  winRate     Float    @default(0)
  unitsProfit Float    @default(0)
  roiPercent  Float    @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([period, sportKey])
  @@index([period])
}

// ─── Odds platform (internal + public board + developer API) ───

model SportsEvent {
  id            String    @id @default(cuid())
  externalId    String    @unique
  sport         Sport
  league        String?
  homeTeam      String
  awayTeam      String
  eventName     String
  commenceTime  DateTime?
  isLive        Boolean   @default(false)
  lastSeenAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  markets Market[]

  @@index([sport, commenceTime])
  @@index([lastSeenAt])
}

model Market {
  id           String   @id @default(cuid())
  eventId      String
  marketKey    String // h2h | spreads | totals
  selection    String // team name, Over, Under, etc.
  /// Point as string key so null spreads/totals stay unique ("")
  pointKey     String   @default("")
  point        Float?
  bookmaker    String
  oddsAmerican Int
  capturedAt   DateTime @default(now())

  event     SportsEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  snapshots OddsSnapshot[]

  @@unique([eventId, marketKey, selection, pointKey, bookmaker])
  @@index([eventId, marketKey])
  @@index([capturedAt])
}

/// Historical price points for line-move analysis
model OddsSnapshot {
  id           String   @id @default(cuid())
  marketId     String
  oddsAmerican Int
  point        Float?
  capturedAt   DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, capturedAt])
  @@index([capturedAt])
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String    @default("Default")
  /// Public prefix for display e.g. be_live_xxxx
  keyPrefix   String
  /// SHA-256 hash of full key (never store raw key)
  keyHash     String    @unique
  /// FREE tier keys limited; PRO gets higher quota
  planTier    Plan      @default(FREE)
  requestsDay Int       @default(0)
  requestsAll Int       @default(0)
  lastUsedAt  DateTime?
  lastResetAt DateTime  @default(now())
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage ApiKeyUsage[]

  @@index([userId])
  @@index([keyPrefix])
}

model ApiKeyUsage {
  id        String   @id @default(cuid())
  apiKeyId  String
  path      String
  status    Int
  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([createdAt])
}

/// Promo / founder codes that grant a plan without Stripe
model PromoCode {
  id             String    @id @default(cuid())
  /// Stored uppercase, e.g. BETEDGE-PRO-OWNER
  code           String    @unique
  plan           Plan      @default(PRO)
  description    String?
  maxRedemptions Int? // null = unlimited
  redemptionCount Int      @default(0)
  active         Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  redemptions PromoRedemption[]

  @@index([active])
}

model PromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([userId])
}
