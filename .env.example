# App
# Production: https://www.betedge-ai.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BetEdge AI

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Auth.js â€” generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Optional Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# AI — required for pick generation (no mock fallback)
XAI_API_KEY=
XAI_MODEL=grok-4.3

# Odds / sports data — required (no mock fallback)
# Stake.com GraphQL token — partner book odds (preferred when set)
STAKE_API_KEY=
# The Odds API — multi-sport US books https://the-odds-api.com
ODDS_API_KEY=
# API-Sports football — global soccer free tier https://www.api-football.com
API_SPORTS_KEY=

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PORTAL_CONFIGURATION_ID=bpc_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email digests (Resend) — optional; digests skip cleanly if unset
RESEND_API_KEY=
EMAIL_FROM=BetEdge AI <onboarding@resend.dev>

# Cron auth — required in production (Bearer token for /api/cron/*)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Seed admin (used by prisma/seed.ts)
ADMIN_EMAIL=admin@betedge.ai
ADMIN_PASSWORD=ChangeMeAdmin123!

# Promo codes that grant PRO without Stripe (comma-separated, optional)
# Default code always accepted: BETEDGE-PRO-OWNER
PROMO_CODE_PRO=BETEDGE-PRO-OWNER

