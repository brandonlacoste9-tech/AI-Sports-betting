# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BetEdge AI

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Auth.js — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Optional Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# AI (optional in dev — mock picks used if empty)
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# Odds API (optional — mock data if empty) https://the-odds-api.com
ODDS_API_KEY=

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...

# Email (optional)
RESEND_API_KEY=
EMAIL_FROM=BetEdge AI <onboarding@resend.dev>

# Seed admin (used by prisma/seed.ts)
ADMIN_EMAIL=admin@betedge.ai
ADMIN_PASSWORD=ChangeMeAdmin123!
